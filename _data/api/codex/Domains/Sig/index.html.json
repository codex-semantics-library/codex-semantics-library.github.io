\"><a href=\"#module-Convert_Integer_Forward\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Convert_Integer_Forward/index.html\">Convert_Integer_Forward</a></span><span>\u000A  (<a href=\"Convert_Integer_Forward/argument-1-C/index.html\">C</a> : <a href=\"module-type-Convert_Contexts/index.html\">Convert_Contexts</a>)\u000A  (<a href=\"Convert_Integer_Forward/argument-2-D/index.html\">D</a> : <a href=\"module-type-With_Integer_Forward/index.html\">With_Integer_Forward</a> <span class=\"keyword\">with</span> <span><span class=\"keyword\">module</span> <a href=\"module-type-With_Integer_Forward/Context/index.html\">Context</a> = <a href=\"Convert_Integer_Forward/argument-1-C/To/index.html\">C.To</a></span>) : \u000A  <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Convert_Binary_Forward\"><a href=\"#module-Convert_Binary_Forward\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Convert_Binary_Forward/index.html\">Convert_Binary_Forward</a></span><span>\u000A  (<a href=\"Convert_Binary_Forward/argument-1-C/index.html\">C</a> : <a href=\"module-type-Convert_Contexts/index.html\">Convert_Contexts</a>)\u000A  (<a href=\"Convert_Binary_Forward/argument-2-D/index.html\">D</a> : <a href=\"module-type-With_Binary_Forward/index.html\">With_Binary_Forward</a> <span class=\"keyword\">with</span> <span><span class=\"keyword\">module</span> <a href=\"module-type-With_Binary_Forward/Context/index.html\">Context</a> = <a href=\"Convert_Binary_Forward/argument-1-C/To/index.html\">C.To</a></span>) : \u000A  <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Convert_Enum_Forward\"><a href=\"#module-Convert_Enum_Forward\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Convert_Enum_Forward/index.html\">Convert_Enum_Forward</a></span><span>\u000A  (<a href=\"Convert_Enum_Forward/argument-1-C/index.html\">C</a> : <a href=\"module-type-Convert_Contexts/index.html\">Convert_Contexts</a>)\u000A  (<a href=\"Convert_Enum_Forward/argument-2-D/index.html\">D</a> : <a href=\"module-type-With_Enum_Forward/index.html\">With_Enum_Forward</a> <span class=\"keyword\">with</span> <span><span class=\"keyword\">module</span> <a href=\"module-type-With_Enum_Forward/Context/index.html\">Context</a> = <a href=\"Convert_Enum_Forward/argument-1-C/To/index.html\">C.To</a></span>) : \u000A  <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Convert_to_monadic\"><a href=\"#module-Convert_to_monadic\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Convert_to_monadic/index.html\">Convert_to_monadic</a></span><span> (<a href=\"Convert_to_monadic/argument-1-D/index.html\">D</a> : <a href=\"module-type-BASE/index.html\">BASE</a>) : <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div><div class=\"spec-doc\"><p>This will help to the transition in a top-down manner, starting from the translation and top-level domain to the lower-level domain.</p></div></div>"}